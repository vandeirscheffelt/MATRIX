generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["atendente_ia"]
}

// =============================================================================
// SchAiKron — Atendente IA
// Schema: atendente_ia (isolado, não misturar com public)
// =============================================================================

// -----------------------------------------------------------------------------
// Tenant principal
// -----------------------------------------------------------------------------

model Empresa {
  id        String   @id @default(uuid())
  nome      String
  slug      String   @unique
  timezone  String   @default("America/Sao_Paulo")
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuarios         Usuario[]
  subscription     Subscription?
  profissionais    Profissional[]
  servicos         Servico[]
  instancia        InstanciaWhatsApp?
  configBot        ConfigBot?
  numerosGerente   NumeroGerente[]
  leads            Lead[]
  conversas        Conversa[]
  agendamentos     Agendamento[]
  chatHistories    ChatHistory[]
  eventos          AnalyticsEvento[]
  faqEntries       FaqEntry[]
  faqSugestoes     FaqSugestao[]
  keywords         Keyword[]
  produtosAfiliados ProdutoAfiliado[]

  @@map("empresas")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Usuários da empresa (FK para auth.users do Supabase)
// -----------------------------------------------------------------------------

model Usuario {
  id        String   @id // mesmo UUID do auth.users
  empresaId String   @map("empresa_id")
  role      RoleUsuario @default(ADMIN)
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa       Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  profissional  Profissional?

  @@map("usuarios")
  @@schema("atendente_ia")
}

enum RoleUsuario {
  ADMIN
  PROFISSIONAL
  ADMIN_GLOBAL
  ACCOUNT_OWNER

  @@map("role_usuario_enum")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Plano / Trial / Stripe
// -----------------------------------------------------------------------------

model Subscription {
  id                     String             @id @default(uuid())
  empresaId              String             @unique @map("empresa_id")
  stripeCustomerId       String?            @map("stripe_customer_id")
  stripeSubscriptionId   String?            @map("stripe_subscription_id")
  status                 StatusSubscription @default(TRIAL)
  trialEndsAt            DateTime?          @map("trial_ends_at")
  periodEndsAt           DateTime?          @map("period_ends_at")
  criadoEm               DateTime           @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
  @@schema("atendente_ia")
}

enum StatusSubscription {
  TRIAL
  ACTIVE
  CANCELED
  PAST_DUE

  @@map("status_subscription_enum")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Afiliados
// -----------------------------------------------------------------------------

model ProdutoAfiliado {
  id               String   @id @default(uuid())
  empresaId        String   @map("empresa_id")
  productName      String   @map("product_name")
  shortDescription String   @default("") @map("short_description")
  status           String   @default("active") @map("status")
  externalLink     String   @map("external_link")
  icon             String   @default("🤝") @map("icon")
  highlightBadge   String   @default("") @map("highlight_badge")
  displayOrder     Int      @default(0) @map("display_order")
  criadoEm         DateTime @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("produtos_afiliados")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Profissionais e Agenda
// -----------------------------------------------------------------------------

model Profissional {
  id                String   @id @default(uuid())
  empresaId         String   @map("empresa_id")
  usuarioId         String?  @unique @map("usuario_id") // nullable — profissional sem login
  nome              String
  telefone          String?  @map("telefone")
  cor               String   @default("217 91% 60%") @map("cor")
  aiAccess          Boolean  @default(false) @map("ai_access")
  duracaoPadraoMin  Int      @default(60) @map("duracao_padrao_min")
  intervaloInicio   String?  @map("intervalo_inicio")
  intervaloFim      String?  @map("intervalo_fim")
  ativo             Boolean  @default(true)
  criadoEm          DateTime @default(now()) @map("criado_em")

  empresa              Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario              Usuario?              @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  gradeHorarios        GradeHorario[]
  bloqueios            Bloqueio[]
  agendamentos         Agendamento[]
  profissionalServicos ProfissionalServico[]

  @@map("profissionais")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Serviços oferecidos pela empresa
// -----------------------------------------------------------------------------

model Servico {
  id        String   @id @default(uuid())
  empresaId String   @map("empresa_id")
  nome      String
  duracaoMin Int     @default(60) @map("duracao_min")
  ordem     Int      @default(0)
  color     String   @default("")
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa              Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  profissionalServicos ProfissionalServico[]
  agendamentos         Agendamento[]

  @@map("servicos")
  @@schema("atendente_ia")
}

model ProfissionalServico {
  profissionalId String @map("profissional_id")
  servicoId      String @map("servico_id")

  profissional Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  servico      Servico      @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  @@id([profissionalId, servicoId])
  @@map("profissional_servicos")
  @@schema("atendente_ia")
}

model GradeHorario {
  id              String   @id @default(uuid())
  profissionalId  String   @map("profissional_id")
  diaSemana       Int      @map("dia_semana") // 0=domingo ... 6=sábado
  horaInicio      String   @map("hora_inicio") // "08:00"
  horaFim         String   @map("hora_fim")    // "18:00"

  profissional Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@map("grade_horarios")
  @@schema("atendente_ia")
}

model Bloqueio {
  id              String   @id @default(uuid())
  profissionalId  String   @map("profissional_id")
  dataInicio      DateTime @map("data_inicio")
  dataFim         DateTime @map("data_fim")
  motivo          String?

  profissional Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@map("bloqueios")
  @@schema("atendente_ia")
}

model Agendamento {
  id              String             @id @default(uuid())
  empresaId       String             @map("empresa_id")
  profissionalId  String             @map("profissional_id")
  leadId          String?            @map("lead_id")
  clienteNome     String?            @map("cliente_nome")
  clienteTelefone String?            @map("cliente_telefone")
  servicoNome     String?            @map("servico_nome")
  servicoId       String?            @map("servico_id")
  inicio          DateTime
  fim             DateTime
  status          StatusAgendamento  @default(CONFIRMADO)
  criadoEm        DateTime           @default(now()) @map("criado_em")

  empresa      Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  profissional Profissional @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  servico      Servico?     @relation(fields: [servicoId], references: [id], onDelete: SetNull)

  @@index([empresaId, inicio])
  @@index([profissionalId, inicio])
  @@map("agendamentos")
  @@schema("atendente_ia")
}

enum StatusAgendamento {
  CONFIRMADO
  CANCELADO
  REMARCADO
  REALIZADO
  NO_SHOW

  @@map("status_agendamento_enum")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// WhatsApp — Instância Evolution API
// -----------------------------------------------------------------------------

model InstanciaWhatsApp {
  id              String   @id @default(uuid())
  empresaId       String   @unique @map("empresa_id")
  nomeInstancia   String   @unique @map("nome_instancia")
  token           String
  status          StatusInstancia @default(DISCONNECTED)
  qrCodeBase64    String?  @map("qr_code_base64") @db.Text
  qrExpiresAt     DateTime? @map("qr_expires_at")
  criadoEm        DateTime @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("instancias_whatsapp")
  @@schema("atendente_ia")
}

enum StatusInstancia {
  DISCONNECTED
  CONNECTING
  CONNECTED

  @@map("status_instancia_enum")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Configuração do Bot
// -----------------------------------------------------------------------------

model ConfigBot {
  id                   String   @id @default(uuid())
  empresaId            String   @unique @map("empresa_id")
  prompt               String   @db.Text
  tom                  TomBot   @default(FORMAL)
  palavraPausa         String   @default("#humano") @map("palavra_pausa")
  palavraRetorno       String   @default("#bot") @map("palavra_retorno")
  tempoRetornoMin      Int?     @map("tempo_retorno_min")
  faq                  Json     @default("[]")
  botAtivo             Boolean  @default(true) @map("bot_ativo")
  idioma               String   @default("pt-BR")
  tipoNegocio          String?  @map("tipo_negocio")
  contextoOperacional  String?  @map("contexto_operacional") @db.Text
  identidade           String   @default("assistente_virtual")
  disponibilidade      String   @default("horario_comercial")
  horarioInicio        String   @default("08:00") @map("horario_inicio")
  horarioFim           String   @default("18:00") @map("horario_fim")
  nomeAssistente       String   @default("Assistente") @map("nome_assistente")
  tomDisplay                    String?  @map("tom_display")
  confirmacaoAntecedenciaHoras  Int?     @default(2) @map("confirmacao_antecedencia_horas")
  criadoEm             DateTime @default(now()) @map("criado_em")
  atualizadoEm         DateTime @updatedAt @map("atualizado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("config_bot")
  @@schema("atendente_ia")
}

enum TomBot {
  FORMAL
  INFORMAL

  @@map("tom_bot_enum")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Número do Gerente (segundo número)
// -----------------------------------------------------------------------------

model NumeroGerente {
  id               String          @id @default(uuid())
  empresaId        String          @map("empresa_id")
  telefone         String
  resumoAtivo      Boolean         @default(false) @map("resumo_ativo")
  resumoIntervalo  IntervaloResumo? @map("resumo_intervalo")
  resumoHorario    String?         @map("resumo_horario") // "08:00"
  criadoEm         DateTime        @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("numeros_gerente")
  @@schema("atendente_ia")
}

enum IntervaloResumo {
  DIARIO
  SEMANAL

  @@map("intervalo_resumo_enum")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Leads e Conversas
// -----------------------------------------------------------------------------

model Lead {
  id        String   @id @default(uuid())
  empresaId String   @map("empresa_id")
  telefone  String
  nomeWpp   String?  @map("nome_wpp")
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa      Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  conversa     Conversa?
  agendamentos Agendamento[]

  @@unique([empresaId, telefone])
  @@map("leads")
  @@schema("atendente_ia")
}

model Conversa {
  id              String       @id @default(uuid())
  leadId          String       @unique @map("lead_id")
  empresaId       String       @map("empresa_id")
  statusIa        StatusIa     @default(ATIVO) @map("status_ia")
  pausadoEm       DateTime?    @map("pausado_em")
  retornoEm       DateTime?    @map("retorno_em")
  arquivada       Boolean      @default(false)
  resolvidaEm     DateTime?    @map("resolvida_em")
  ultimaMensagem  String?      @map("ultima_mensagem") @db.Text
  ultimaAtividade DateTime?    @map("ultima_atividade")
  atualizadoEm    DateTime     @updatedAt @map("atualizado_em")

  lead          Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  empresa       Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  mensagens     MensagemConversa[]
  faqSugestoes  FaqSugestao[]

  @@map("conversas")
  @@schema("atendente_ia")
}

model MensagemConversa {
  id          String   @id @default(uuid())
  conversaId  String   @map("conversa_id")
  origem      OrigemMensagem
  conteudo    String   @db.Text
  criadoEm   DateTime @default(now()) @map("criado_em")

  conversa Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  @@index([conversaId, criadoEm])
  @@map("mensagens_conversa")
  @@schema("atendente_ia")
}

enum OrigemMensagem {
  LEAD
  BOT
  HUMANO

  @@map("origem_mensagem_enum")
  @@schema("atendente_ia")
}

enum StatusIa {
  ATIVO
  PAUSADO

  @@map("status_ia_enum")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Histórico de Conversa (usado pelo n8n Postgres Chat Memory)
// -----------------------------------------------------------------------------

model ChatHistory {
  id        BigInt   @id @default(autoincrement())
  sessionId String   @map("session_id") // telefone do lead
  empresaId String   @map("empresa_id")
  message   Json
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([sessionId, empresaId])
  @@map("chat_histories")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// FAQ
// -----------------------------------------------------------------------------

model FaqEntry {
  id        String   @id @default(uuid())
  empresaId String   @map("empresa_id")
  pergunta  String
  resposta  String
  origem    String   @default("manual") // 'manual' | 'sugestao_ia'
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@map("faq_entries")
  @@schema("atendente_ia")
}

model FaqSugestao {
  id                String    @id @default(uuid())
  empresaId         String    @map("empresa_id")
  pergunta          String
  respostaSugerida  String    @map("resposta_sugerida")
  status            String    @default("pendente") // 'pendente' | 'aprovada' | 'rejeitada'
  origemConversaId  String?   @map("origem_conversa_id")
  criadoEm          DateTime  @default(now()) @map("criado_em")

  empresa  Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  conversa Conversa? @relation(fields: [origemConversaId], references: [id], onDelete: SetNull)

  @@index([empresaId, status])
  @@map("faq_sugestoes")
  @@schema("atendente_ia")
}

model Keyword {
  id        String   @id @default(uuid())
  empresaId String   @map("empresa_id")
  palavra   String
  origem    String   @default("manual") // 'manual' | 'sugestao_ia'
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, palavra])
  @@map("keywords")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Admin — Pricing, Produtos e Módulos
// -----------------------------------------------------------------------------

model PricingVersion {
  id          String    @id @default(uuid())
  nome        String
  descricao   String?
  ativa       Boolean   @default(false)
  payload     Json      @default("{}")
  criadoEm    DateTime  @default(now()) @map("criado_em")
  ativadoEm   DateTime? @map("ativado_em")

  @@map("pricing_versions")
  @@schema("atendente_ia")
}

model ExternalProduct {
  id        String   @id @default(uuid())
  nome      String
  descricao String?
  url       String?
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("external_products")
  @@schema("atendente_ia")
}

model InternalModule {
  id             String   @id @default(uuid())
  nome           String
  descricao      String?
  chave          String   @unique
  icon           String   @default("🧩")
  highlightBadge String   @default("") @map("highlight_badge")
  routePath      String   @default("") @map("route_path")
  displayOrder   Int      @default(0) @map("display_order")
  status         String   @default("active")
  requiresPlan   Boolean  @default(false) @map("requires_plan")
  stripePriceId  String?  @map("stripe_price_id")
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now()) @map("criado_em")

  @@map("internal_modules")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Tutoriais
// -----------------------------------------------------------------------------

model Tutorial {
  id          String   @id @default(uuid())
  titulo      String
  descricao   String?  @db.Text
  videoUrl    String   @map("video_url")
  categoria   String   @default("primeiros_passos")
  ordem       Int      @default(0)
  obrigatorio Boolean  @default(false)
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now()) @map("criado_em")

  @@map("tutorials")
  @@schema("atendente_ia")
}

// -----------------------------------------------------------------------------
// Analytics
// -----------------------------------------------------------------------------

model AnalyticsEvento {
  id        String   @id @default(uuid())
  empresaId String   @map("empresa_id")
  tipo      String   // 'agendamento' | 'cancelamento' | 'pausa_ia' | etc
  payload   Json?
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, tipo])
  @@map("analytics_eventos")
  @@schema("atendente_ia")
}
