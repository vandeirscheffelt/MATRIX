{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "ignoreDeprecations": "5.0",
    "outDir": "./dist",
    "rootDir": "./src/manifest-src",
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/manifest-src/manifest.ts"],
  "exclude": ["node_modules"]
}
