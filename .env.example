# =============================================================================
# .env.example — Matrix Monorepo
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
WEB_URL=http://localhost:3000          # URL do Next.js (CORS no Fastify)
PORT=3001                              # Porta do Fastify

# -----------------------------------------------------------------------------
# Supabase
# — NEXT_PUBLIC_* são lidos pelo Next.js no browser (anon key apenas)
# — SUPABASE_SERVICE_ROLE_KEY só server-side (nunca expor no frontend)
# — SUPABASE_URL / SUPABASE_KEY são aliases para apps Node.js (scraper, etc.)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # Painel Supabase → Settings → API → anon key
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # Painel Supabase → Settings → API → service_role key
SUPABASE_URL=https://xxxx.supabase.co  # Alias para apps Node.js (mesmo valor de NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_KEY=eyJ...                    # Alias para apps Node.js (mesmo valor de SUPABASE_SERVICE_ROLE_KEY)

# -----------------------------------------------------------------------------
# Banco de dados (Supabase / PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[SENHA]@db.xxxx.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[SENHA]@db.xxxx.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...              # ID do plano mensal único (R$ 97/mês)

# -----------------------------------------------------------------------------
# OpenAI — usado para geração de prompt e IA de configuração
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Anthropic (Claude API) — usado pelo lovable-proxy
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Evolution API (WhatsApp)
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080        # URL da sua VPS
EVOLUTION_API_KEY=sua-chave-global-aqui        # Global API Key da Evolution API

# -----------------------------------------------------------------------------
# n8n Webhook Secret — segredo compartilhado entre Fastify e n8n
# Gere com: openssl rand -hex 32
# -----------------------------------------------------------------------------
N8N_WEBHOOK_SECRET=troque-por-valor-seguro-gerado-com-openssl

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
MATRIX_REDIS_URL=redis://127.0.0.1:6379
